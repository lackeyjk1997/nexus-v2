# Copy to .env.local and fill in real values. Never commit .env.local.
# Variables are grouped by the Phase 1 day they are first needed.

# ---- Day 2: Supabase ----
# Project "nexus-v2" at https://supabase.com. Variable names match `npx vercel env pull` output.
NEXT_PUBLIC_SUPABASE_URL=REDACTED
NEXT_PUBLIC_SUPABASE_ANON_KEY=REDACTED
SUPABASE_SERVICE_ROLE_KEY=REDACTED
# DATABASE_URL → Supabase Transaction pooler (port 6543, aws-0-<region>.pooler.supabase.com). IPv4-friendly for Vercel.
# DIRECT_URL   → Supabase Direct connection (port 5432, db.<ref>.supabase.co). IPv6, used by drizzle-kit from developer machines.
# Do NOT point the Vercel-deployed app at DIRECT_URL — Vercel is IPv4 and can't resolve db.<ref>.supabase.co.
DATABASE_URL=REDACTED
DIRECT_URL=REDACTED

# ---- Day 4: Anthropic ----
# Pin the model string via env so upgrades don't require code changes.
# Wrapper and prompt files must never hardcode a model ID.
# See DECISIONS.md 2.13, Guardrail 16-18.
ANTHROPIC_API_KEY=REDACTED
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Day 5: HubSpot ----
# See docs/handoff/07C-HUBSPOT-SETUP.md for provisioning playbook.
# DECISIONS.md 2.18.1 locks the config file paths (pipeline-ids.json, properties.ts).
#
# NEXUS_HUBSPOT_TOKEN         — private app access token (crm.* scopes per 07C §6.2).
# HUBSPOT_PORTAL_ID           — numeric portal/hub ID from Settings → Account Defaults.
# HUBSPOT_CLIENT_SECRET       — private app client secret. ALSO used for webhook v3
#                               signature verification (07C §5.5). No separate
#                               "webhook secret" is generated — HUBSPOT_WEBHOOK_SECRET
#                               from pre-Day-5 env.example drafts is retired.
# HUBSPOT_APP_ID              — private app numeric ID (different from portal ID).
#                               Copy from the Settings URL bar:
#                               https://app.hubspot.com/private-apps/{portalId}/{appId}
#                               Required for scripts/hubspot-subscribe-webhooks.ts.
NEXUS_HUBSPOT_TOKEN=REDACTED
HUBSPOT_PORTAL_ID=REDACTED
HUBSPOT_CLIENT_SECRET=REDACTED
HUBSPOT_APP_ID=REDACTED

# ---- Day 3: Jobs / pg_cron ----
# Shared secret between pg_cron's http_get and the /api/jobs/worker route.
# Set identically in Vercel (Production + Preview + Development) and locally.
# Generate a new one with: openssl rand -hex 32
CRON_SECRET=REDACTED

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3001
